# Browser-safe public configuration.
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<supabase-anon-or-publishable-key>

# Server-only auth flags.
AUTH_APPLE_OAUTH_ENABLED=false
AUTH_GOOGLE_OAUTH_ENABLED=false

# Server-only payment flags. Keep both false/unset by default.
PAYMENTS_ENABLED=false
PAYMENTS_DEV_BYPASS_ENABLED=false

# Server-only Supabase/Postgres.
SUPABASE_SERVICE_ROLE_KEY=<supabase-service-role-key>
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@<pooler-host>:5432/postgres

# Server-only Apple Music developer token configuration.
APPLE_TEAM_ID=<apple-team-id>
APPLE_KEY_ID=<apple-key-id>
APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n<apple-private-key-body>\n-----END PRIVATE KEY-----"
APPLE_MUSICKIT_KEY=<apple-musickit-key-or-bundle-id>

# Server-only OpenAI.
OPENAI_API_KEY=<openai-api-key>

# Server-only Stripe. Optional while payment is blocked.
STRIPE_SECRET_KEY=<stripe-secret-key>
STRIPE_WEBHOOK_SECRET=<stripe-webhook-secret>
STRIPE_PRICE_SORT=<stripe-price-id>

# Server-only observability. Optional.
SENTRY_DSN=<sentry-dsn>

# Server-only encryption key for Apple Music user tokens.
ENCRYPTION_KEY=<32-byte-random-hex-or-base64-key>
